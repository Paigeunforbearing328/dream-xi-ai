# =============================================================================
# Dream XI AI — 环境变量配置模板
# 复制此文件为 .env 并填写你的配置：cp .env.example .env
# .env 文件不会被提交到 Git（球队铁律：不提交 API Key）
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------

# Dream XI 服务监听端口（默认 3003）
PORT=3003

# 服务运行环境：development | production | test
NODE_ENV=development

# 服务基础 URL（用于回调和链接生成）
BASE_URL=http://localhost:3003

# -----------------------------------------------------------------------------
# 存储配置
# -----------------------------------------------------------------------------

# Redis 连接 URL（留空则自动使用内存模式，等同于 --memory 标志）
# 生产环境强烈建议配置 Redis，否则重启后所有比赛记忆将丢失
# 格式：redis://[:password@]host[:port][/db]
REDIS_URL=redis://localhost:6379

# Redis 连接超时（毫秒）
REDIS_CONNECT_TIMEOUT=5000

# -----------------------------------------------------------------------------
# AI 模型 API Keys（球员配置）
# 至少配置一个球员即可开始使用
# 也可在启动后通过 UI（更衣室 → 账号配置）设置
# -----------------------------------------------------------------------------

# #10 队长 Leo — Claude (Anthropic)
# 获取：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# #8 中场 André — GPT / Codex (OpenAI)
# 获取：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# #9 前锋 Flash — Gemini (Google)
# 获取：https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# opencode 使用的默认模型提供商（可选）
# 支持：anthropic | openai | google | custom
OPENCODE_DEFAULT_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# 替补球员 / 第三方模型（可选）
# -----------------------------------------------------------------------------

# Kimi (Moonshot AI)
# 获取：https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# 智谱 GLM
# 获取：https://open.bigmodel.cn/
ZHIPU_API_KEY=

# MiniMax
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# 自定义 OpenAI 兼容接口（如本地 Ollama、LM Studio 等）
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# -----------------------------------------------------------------------------
# 多平台网关（可选）
# -----------------------------------------------------------------------------

# 飞书（Lark）机器人
# 配置指南：docs/integrations/feishu.md
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Telegram 机器人（进行中）
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# GitHub 集成（可选）
# -----------------------------------------------------------------------------

# GitHub OAuth App（用于 PR Review 路由和多用户登录）
# 创建：https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Webhook Secret（用于 PR Review 路由）
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# MCP 配置（可选）
# -----------------------------------------------------------------------------

# MCP 服务器监听端口（默认 3004）
MCP_PORT=3004

# MCP Callback Bridge 超时（毫秒）
MCP_CALLBACK_TIMEOUT=30000

# -----------------------------------------------------------------------------
# 安全配置
# -----------------------------------------------------------------------------

# JWT 签名密钥（多用户模式必填，请使用强随机字符串）
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Session 有效期（默认 7d，支持 ms 格式：7d, 24h, 3600000）
JWT_EXPIRES_IN=7d

# CORS 允许的来源（逗号分隔，留空则允许所有来源）
CORS_ORIGINS=http://localhost:3003

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------

# 日志级别：error | warn | info | debug | trace
LOG_LEVEL=info

# 日志格式：json | pretty
LOG_FORMAT=pretty

# 日志文件路径（留空则仅输出到控制台）
LOG_FILE=
